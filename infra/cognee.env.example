# Cognee sidecar configuration (copy to cognee.env and set LLM_API_KEY)
# Used by docker compose cognee service — keep in sync with apps/api/.env GEMINI_API_KEY

LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=your-gemini-api-key-here

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_API_KEY=your-gemini-api-key-here

ENVIRONMENT=local
LOG_LEVEL=INFO

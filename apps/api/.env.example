# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://consilium:consilium_dev@localhost:5432/consilium

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=consilium-dev-secret-change-in-production

# ─── AI Services ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# ─── Presidio (PII Detection) ────────────────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://localhost:5001
PRESIDIO_ANONYMIZER_URL=http://localhost:5002

# ─── Cognee (memory sidecar) ───────────────────────────────────────────────────
COGNEE_BASE_URL=http://localhost:8000
COGNEE_API_KEY=
COGNEE_DATASET=acme-litigation
COGNEE_ENABLED=true
COGNEE_FALLBACK_TO_PGVECTOR=true

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
